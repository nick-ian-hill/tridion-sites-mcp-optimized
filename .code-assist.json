        "getItemsInContainer",
        "getKeywordsForCategory",
        "getPublications",
        "getPublicationTypes",
        "dependencyGraphForItem",
        "createItem",
        "createPublication",
        "createRootStructureGroup",
        "createSchema",
        "updateComponentById",
        "updateItemById",
        "updatePublicationById",
        "copyItem",
        "moveItem",
        "deleteItem",
        "deletePublicationById",
        "deleteComponentById",
        "localizeItemById",
        "unlocalizeItemById",
        "batchLocalizeItemsById",
        "batchUnlocalizeItemsById",
        "promoteItem",
        "demoteItem",
        "checkOutItem",
        "checkInItem",
        "undoCheckOutItem"
      ],
      "cwd": "."
