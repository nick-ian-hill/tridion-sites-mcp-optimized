{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/modelcontextprotocol/main/schema/2025-03-26/schema.json",
  "ignore": [
    "node_modules",
    "dist",
    "build"
  ],
  "tools": [
    {
      "name": "mcp-test-server",
      "displayName": "Tridion Sites MCP Server",
